{
  "productName": "Lowkey VPN",
  "version": "1.0.0",
  "identifier": "com.lowkey.vpn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lowkey VPN",
        "width": 420,
        "height": 680,
        "resizable": false,
        "center": true,
        "decorations": true,
        "visible": true,
        "closable": true,
        "minimizable": true,
        "maximizable": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "Lowkey VPN"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "Network",
    "shortDescription": "Secure VPN client",
    "longDescription": "Lowkey VPN — secure, fast and private VPN service"
  },
  "plugins": {
    "autostart": {
      "mobile": false,
      "desktop": true
    }
  }
}
