# =============================================================================
# Lowkey VPN — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables are marked with [REQUIRED].
# Optional variables with defaults are marked with [OPTIONAL: default].
# =============================================================================


# ── Database ──────────────────────────────────────────────────────────────────

# [REQUIRED] PostgreSQL connection URL.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# When using docker-compose, this is set automatically.
# For local development: postgres://lowkey:lowkey@localhost/lowkey
DATABASE_URL=postgres://lowkey:lowkey@localhost/lowkey


# ── Security ──────────────────────────────────────────────────────────────────

# [REQUIRED] JWT signing secret. Generate with:
#   head -c 48 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c 48
JWT_SECRET=change_this_to_a_random_secret_at_least_32_chars

# [REQUIRED] VPN tunnel pre-shared key. Must match on server and all clients.
# Generate with:
#   head -c 32 /dev/urandom | base64 | tr -dc 'a-zA-Z0-9' | head -c 32
VPN_PSK=change_this_to_a_random_psk


# ── Network ports ─────────────────────────────────────────────────────────────

# [OPTIONAL: 8080] HTTP API port. Used by web dashboard and clients.
API_PORT=8080

# [OPTIONAL: 51820] UDP port for the VPN tunnel. Must be open in your firewall.
UDP_PORT=51820

# [OPTIONAL: 8388] TCP port for the SOCKS5/VLESS proxy.
PROXY_PORT=8388


# ── Telegram (Admin OTP) ──────────────────────────────────────────────────────
# Used to deliver one-time login codes to the admin panel.
# Create a bot via @BotFather and get your chat ID via @userinfobot.

# [OPTIONAL] Telegram bot token from @BotFather.
TG_BOT_TOKEN=

# [OPTIONAL] Your Telegram chat ID (numeric). Get it from @userinfobot.
TG_ADMIN_CHAT_ID=


# ── Tochka Bank SBP Payments ─────────────────────────────────────────────────
# Required only if you want to accept SBP QR payments.
# Register at https://enter.tochka.com/merchant/sbp

# [OPTIONAL] JWT API token from Tochka Bank developer console.
TOCHKA_JWT=

# [OPTIONAL] Merchant ID from Tochka Bank.
TOCHKA_MERCHANT_ID=

# [OPTIONAL] Legal entity ID from Tochka Bank.
TOCHKA_LEGAL_ID=


# ── Web Dashboard ─────────────────────────────────────────────────────────────

# [OPTIONAL: http://localhost:8080] URL of the VPN server API as seen from the
# browser (or from the Next.js server for server-side requests).
# In production, set this to your public server URL.
NEXT_PUBLIC_API_URL=http://localhost:8080


# ── Docker Compose only ───────────────────────────────────────────────────────

# [OPTIONAL: change_me_in_env] PostgreSQL password when using docker-compose.
# The DATABASE_URL above is set automatically from this value in docker-compose.
POSTGRES_PASSWORD=change_me_in_env
