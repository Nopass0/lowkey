# Keep node_modules and build artifacts out of Docker build context
# These are large and not needed inside the container

# Node.js artifacts
node_modules
npm-debug.log*
.npm

# Specific node_modules paths
vpn-desktop/node_modules
web/.next
web/node_modules

# Rust build cache (large, not needed in build context)
target

# Desktop app artifacts
vpn-desktop/dist

# Git metadata
.git
.gitignore

# CI/CD
.github

# IDE files
.vscode
.idea
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Local env files (written by CI to /opt/lowkey/.env separately)
# .env is intentionally NOT excluded so it can be read by docker-compose
